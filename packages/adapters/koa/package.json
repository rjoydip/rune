{
  "name": "@rune/adapter-koa",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build:dev": "bun build --entrypoints src/index.ts --outdir dist --no-sourcemap --format esm",
    "build": "bun build --entrypoints src/index.ts --outdir dist --minify --no-sourcemap --format esm",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rune/core": "workspace:*",
    "koa": "^2.14.2"
  },
  "devDependencies": {
    "@types/koa": "^2.13.9"
  }
}
