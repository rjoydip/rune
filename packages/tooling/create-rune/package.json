{
  "name": "@rune/create-rune",
  "version": "0.0.0",
  "bin": {
    "create-rune": "./dist/index.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build:dev": "bun build --entrypoints src/index.ts --outdir dist --no-sourcemap --format esm",
    "build": "bun build --entrypoints src/index.ts --outdir dist --minify --no-sourcemap --format esm",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@rune/tsconfig": "*"
  }
}
