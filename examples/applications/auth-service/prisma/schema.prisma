generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Token {
  id        String   @id @default(cuid())
  value     String   @unique
  email     String
  createdAt DateTime @default(now())
}
