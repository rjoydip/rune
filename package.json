{
  "name": "rune",
  "version": "0.0.0",
  "private": true,
  "description": "A batteries-included, web-standard, runtime-agnostic backend framework",
  "workspaces": [
    "packages/foundation/*",
    "packages/runtime/*",
    "packages/infrastructure/*",
    "packages/contracts/*",
    "packages/tooling/*",
    "packages/adapters/*",
    "examples/adapters/*",
    "examples/contracts/*",
    "examples/foundation/*",
    "examples/infrastructure/*",
    "examples/applications/*",
    "runtime-tests/*",
    "benchmarks"
  ],
  "scripts": {
    "prepare": "simple-git-hooks",
    "build:dev": "turbo run build:dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "bunx oxlint .",
    "format": "bunx oxfmt . --write",
    "dev": "turbo run build:dev --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:runtime:cloudflare": "bun test runtime-tests/cloudflare/",
    "test:runtime:deno": "bun test runtime-tests/deno/",
    "test:runtime:vercel": "bun test runtime-tests/vercel/",
    "test:runtime:netlify": "bun test runtime-tests/netlify/",
    "test:runtime:node": "bun test runtime-tests/node/",
    "test:runtime:node-ts": "bun test runtime-tests/node-ts/",
    "fallow": "fallow",
    "actions-up": "actions-up",
    "fallow:audit": "fallow --format compact",
    "fallow:health": "fallow health --format badge > .rune/fallow-health-badge.svg",
    "docs:dev": "cd tools/rune-docs && bun run dev",
    "docs:build": "cd tools/rune-docs && bun run build",
    "docs:preview": "cd tools/rune-docs && bun run preview",
    "clean": "turbo run clean",
    "bundle:size": "bun run scripts/bundle-size.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "actions-up": "^1.15.0",
    "bun-types": "^1.3.14",
    "fallow": "^2.103.0",
    "oxc-transform": "^0.138.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.72.0",
    "pkg-pr-new": "^0.0.75",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.10.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run typecheck && bun run build && bun run actions-up && bun run fallow:health"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.14"
}
